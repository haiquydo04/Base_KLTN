{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-4a5b-9c8d-7e6f5a4b3c2d",
		"name": "Base KLTN - Admin API Collection",
		"description": "Bộ sưu tập API dành riêng cho hệ thống quản trị (Admin Portal). Bao gồm các tính năng: Auth, Password Recovery, User Management, Dashboard và Category Management.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Admin Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.token) {",
									"    pm.environment.set(\"adminToken\", jsonData.token);",
									"    console.log(\"Token updated successfully!\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/admin/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"admin",
								"login"
							]
						},
						"description": "Đăng nhập vào hệ thống quản trị. Sau khi thành công, Token sẽ tự động được lưu vào biến môi trường 'adminToken'."
					},
					"response": []
				},
				{
					"name": "Admin Logout",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/admin/logout",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"admin",
								"logout"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Admin Info (Me)",
